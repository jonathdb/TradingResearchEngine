@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="ml-2">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="8" width="3" height="12" rx="1" fill="currentColor" opacity="0.6"/>
                <rect x="10" y="3" width="3" height="17" rx="1" fill="currentColor"/>
                <rect x="16" y="6" width="3" height="14" rx="1" fill="currentColor" opacity="0.6"/>
            </svg>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Research Engine</MudText>
        </MudStack>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="text-faint mr-4">v3.1</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="padding-top: 64px; padding-left: 16px; padding-right: 16px; padding-bottom: 16px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#4F98A3",
            Secondary = "#2C7873",
            AppbarBackground = "#0F0F0F",
            Background = "#131313",
            Surface = "#1C1C1C",
            DrawerBackground = "#1C1C1C",
            AppbarText = "#E0E0E0",
            TextPrimary = "#E0E0E0",
            TextSecondary = "#A0A0A0",
        }
    };
}
