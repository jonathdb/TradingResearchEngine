@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">TradingResearchEngine</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mr-4" Style="opacity:0.6">v3.0</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always"
               Elevation="2" Variant="DrawerVariant.Mini">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4" Style="margin-top: 48px;">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    <MudText Typo="Typo.h6">Something went wrong</MudText>
                    <MudText Typo="Typo.body2">@ex.Message</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
                               OnClick="ResetError">Try Again</MudButton>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private ErrorBoundary? _errorBoundary;

    private void ResetError() => _errorBoundary?.Recover();

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#FF9800",
            AppbarBackground = "#1565C0",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#FFB74D",
            AppbarBackground = "#1E1E2E",
            Surface = "#1E1E2E",
            Background = "#121212",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
