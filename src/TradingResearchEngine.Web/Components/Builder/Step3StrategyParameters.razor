@* Step 3: Strategy Parameters — grouped by schema, Simple/Advanced toggle *@
@using TradingResearchEngine.Application.Strategy

<MudText Typo="Typo.h6" Class="mb-3">Strategy Parameters</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
    <MudText Typo="Typo.body2">Mode:</MudText>
    <MudToggleGroup T="bool" @bind-Value="Model.AdvancedMode" aria-label="Parameter mode toggle">
        <MudToggleItem Value="false" Text="Simple" aria-label="Simple mode — essential parameters only" />
        <MudToggleItem Value="true" Text="Advanced" aria-label="Advanced mode — all parameters" />
    </MudToggleGroup>
</MudStack>

@if (_validationErrors.Count > 0)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" aria-label="Validation errors summary">
        @_validationErrors.Count parameter(s) have validation errors. Please correct them before proceeding.
    </MudAlert>
}

@if (Schemas.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-3" aria-label="No schema available">
        No parameter schema available for this strategy. Parameters can be edited as key-value pairs.
    </MudAlert>

    @foreach (var key in Model.Parameters.Keys.ToList())
    {
        <MudTextField T="string" Value="@(Model.Parameters[key]?.ToString() ?? "")"
                      ValueChanged="@((string v) => { Model.Parameters[key] = v; Model.IsDirty = true; OnModelChanged.InvokeAsync(); })"
                      Label="@key" Class="mb-2" aria-label="@key"
                      Error="@HasFieldError(key)"
                      ErrorText="@GetFieldError(key)" />
    }
}
else
{
    <ParameterGroupEditor Schemas="@Schemas"
                          Parameters="@Model.Parameters"
                          PresetParameters="@_presetParameters"
                          AdvancedMode="@Model.AdvancedMode"
                          OnParameterChanged="OnParamChanged"
                          ValidationErrors="@_validationErrors" />
}

@code {
    [Parameter] public BuilderViewModel Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<StrategyParameterSchema> Schemas { get; set; } = Array.Empty<StrategyParameterSchema>();
    [Parameter] public Dictionary<string, object>? PresetParameters { get; set; }
    [Parameter] public EventCallback OnModelChanged { get; set; }

    private Dictionary<string, object>? _presetParameters;
    private IReadOnlyList<ValidationError> _validationErrors = Array.Empty<ValidationError>();

    protected override void OnParametersSet()
    {
        _presetParameters = PresetParameters;
        RunValidation();
    }

    private void RunValidation()
    {
        _validationErrors = SchemaValidator.ValidateParameters(Model.Parameters, Schemas);
    }

    private bool HasFieldError(string fieldName) =>
        _validationErrors.Any(e => e.FieldName == fieldName);

    private string GetFieldError(string fieldName) =>
        _validationErrors.FirstOrDefault(e => e.FieldName == fieldName)?.Message ?? "";

    private async Task OnParamChanged((string Key, object Value) change)
    {
        Model.Parameters[change.Key] = change.Value;
        Model.IsDirty = true;
        RunValidation();
        await OnModelChanged.InvokeAsync();
    }
}
