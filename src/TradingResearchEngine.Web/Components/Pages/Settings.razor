@page "/settings"
@inject Microsoft.Extensions.Options.IOptions<TradingResearchEngine.Application.Configuration.RiskOptions> RiskOpts
@inject Microsoft.Extensions.Options.IOptions<TradingResearchEngine.Application.Configuration.MonteCarloOptions> McOpts
@inject Microsoft.Extensions.Options.IOptions<TradingResearchEngine.Application.Configuration.ReportingOptions> ReportOpts
@inject Microsoft.Extensions.Options.IOptions<TradingResearchEngine.Application.Configuration.SweepOptions> SweepOpts
@inject Microsoft.Extensions.Options.IOptions<TradingResearchEngine.Application.Configuration.RepositoryOptions> RepoOpts
@inject TradingResearchEngine.Infrastructure.DataProviders.DataFileService DataService
@inject TradingResearchEngine.Infrastructure.Settings.SettingsService SettingsService
@inject StrategyRegistry Registry

<PageTitle>Settings — TradingResearchEngine</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>
<MudText Typo="Typo.body2" Class="mb-4 text-muted">
    Current configuration values. Edit appsettings.json to change defaults.
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Risk Defaults</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Max Exposure %</td><td>@RiskOpts.Value.MaxExposurePercent%</td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Monte Carlo Defaults</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Simulation Count</td><td>@McOpts.Value.SimulationCount</td></tr>
                    <tr><td>Ruin Threshold</td><td>@McOpts.Value.RuinThresholdPercent.ToString("P0")</td></tr>
                    <tr><td>Seed</td><td>@(McOpts.Value.Seed?.ToString() ?? "Random")</td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Sweep Options</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Max Parallelism</td><td>@SweepOpts.Value.MaxDegreeOfParallelism</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Reporting</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Decimal Places</td><td>@ReportOpts.Value.DecimalPlaces</td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Storage Paths</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Repository</td><td style="word-break:break-all">@(string.IsNullOrEmpty(RepoOpts.Value.BaseDirectory) ? "(default: LocalAppData)" : RepoOpts.Value.BaseDirectory)</td></tr>
                    <tr><td>Data Directory</td><td style="word-break:break-all">@DataService.DataDirectory</td></tr>
                    <tr>
                        <td>QDM Watch Directory</td>
                        <td style="word-break:break-all">
                            @if (_editingQdmPath)
                            {
                                <MudTextField @bind-Value="_qdmWatchDirectory"
                                              HelperText="Optional — path to QDM export folder"
                                              Placeholder="(not configured)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Class="mt-2 mr-2"
                                           OnClick="SaveQdmWatchDirectory">Save</MudButton>
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           Class="mt-2"
                                           OnClick="CancelEditQdmPath">Cancel</MudButton>
                            }
                            else
                            {
                                <span>@(string.IsNullOrEmpty(_qdmWatchDirectory) ? "(not configured)" : _qdmWatchDirectory)</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Class="ml-2"
                                               OnClick="EditQdmPath" />
                            }
                        </td>
                    </tr>
                    <tr>
                        <td>QDM Timezone</td>
                        <td>
                            @if (_editingQdmTimezone)
                            {
                                <MudSelect T="string" @bind-Value="_qdmTimezoneId"
                                        Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="@("UTC")">UTC (recommended)</MudSelectItem>
                                    <MudSelectItem Value="@("Europe/London")">Europe/London (GMT/BST)</MudSelectItem>
                                    <MudSelectItem Value="@("America/New_York")">America/New_York (EST/EDT)</MudSelectItem>
                                    <MudSelectItem Value="@("America/Chicago")">America/Chicago (CST/CDT)</MudSelectItem>
                                    <MudSelectItem Value="@("Asia/Tokyo")">Asia/Tokyo (JST)</MudSelectItem>
                                    <MudSelectItem Value="@("Asia/Singapore")">Asia/Singapore (SGT)</MudSelectItem>
                                    <MudSelectItem Value="@("Europe/Berlin")">Europe/Berlin (CET/CEST)</MudSelectItem>
                                </MudSelect>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                        Size="Size.Small" Class="mt-2 mr-2"
                                        OnClick="SaveQdmTimezone">Save</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                        Class="mt-2" OnClick="CancelEditQdmTimezone">Cancel</MudButton>
                            }
                            else
                            {
                                <span>@(_qdmTimezoneId ?? "UTC")</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                            Size="Size.Small" Class="ml-2"
                                            OnClick="@(() => _editingQdmTimezone = true)" />
                            }
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Registered Strategies</MudText>
            <MudList T="string" Dense="true">
                @foreach (var name in Registry.KnownNames)
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Code">@name</MudListItem>
                }
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>

@* V4: About section *@
<MudGrid Class="mt-4">
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">About</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Version</td><td>4.0.0</td></tr>
                    <tr><td>Build</td><td>@DateTime.Now.ToString("yyyy-MM-dd")</td></tr>
                    <tr><td>Runtime</td><td>.NET @Environment.Version</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>


@code {
    private string? _qdmWatchDirectory;
    private bool _editingQdmPath;

    protected override void OnInitialized()
    {
        var settings = SettingsService.Load();
        _qdmWatchDirectory = settings.QdmWatchDirectory;
        _qdmTimezoneId = settings.QdmTimezoneId ?? "UTC"; 
    }

    private void EditQdmPath()
    {
        _editingQdmPath = true;
    }

    private void CancelEditQdmPath()
    {
        var settings = SettingsService.Load();
        _qdmWatchDirectory = settings.QdmWatchDirectory;
        _editingQdmPath = false;
    }

    private void SaveQdmWatchDirectory()
    {
        var settings = SettingsService.Load();
        var updated = settings with
        {
            QdmWatchDirectory = string.IsNullOrWhiteSpace(_qdmWatchDirectory) ? null : _qdmWatchDirectory.Trim()
        };
        SettingsService.Save(updated);
        _qdmWatchDirectory = updated.QdmWatchDirectory;
        _editingQdmPath = false;
    }
}
