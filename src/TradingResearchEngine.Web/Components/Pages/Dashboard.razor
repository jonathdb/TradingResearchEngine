@page "/"
@using TradingResearchEngine.Application.Strategy
@implements IDisposable
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject IStrategyRepository StrategyRepo
@inject TradingResearchEngine.Application.Research.IStudyRepository StudyRepo
@inject TradingResearchEngine.Application.Research.IRobustnessAdvisoryService RobustnessService
@inject NavigationManager Nav

<PageTitle>Dashboard — Research Engine</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    @* Zone 1 — Strategy Status Strip (Fix 1: CSS vars instead of hex) *@
    <MudText Typo="Typo.subtitle2" Class="text-muted mb-2">YOUR STRATEGIES</MudText>
    <div style="display:flex; gap:12px; overflow-x:auto; padding-bottom:8px; margin-bottom:24px;">
        @foreach (var s in _strategies)
        {
            var lastRun = _lastRunMap.GetValueOrDefault(s.StrategyType);
            <MudPaper Class="@($"pa-3 strategy-strip-card {(lastRun is not null ? "strip-active" : "strip-untested")}")"
                      Style="min-width:180px; cursor:pointer;"
                      Elevation="1" @onclick="@(() => Nav.NavigateTo($"/strategies/{s.StrategyId}"))">
                <MudText Typo="Typo.subtitle2" Style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@s.StrategyName</MudText>
                <MudText Typo="Typo.body2" Class="@GetSharpeClass(lastRun?.SharpeRatio)">
                    Sharpe: @(lastRun?.SharpeRatio?.ToString("F2") ?? "—")
                </MudText>
                <MudText Typo="Typo.caption" Class="text-muted">@(lastRun is not null ? "Active" : "Untested")</MudText>
                <MudText Typo="Typo.caption" Style="font-size:0.7rem" Class="text-faint">@s.Stage</MudText>
            </MudPaper>
        }
        <MudPaper Class="pa-3 d-flex align-center justify-center" Elevation="0"
                  Style="min-width:180px; cursor:pointer; border:1px dashed var(--mud-palette-divider);"
                  @onclick="@(() => Nav.NavigateTo("/strategies/builder"))">
            <MudStack AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Add" Class="text-muted" />
                <MudText Typo="Typo.caption" Class="text-muted">New Strategy</MudText>
            </MudStack>
        </MudPaper>
    </div>

    @* Zone 2 — KPI Tiles *@
    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1" Style="cursor:pointer" @onclick="@(() => Nav.NavigateTo("/strategies/library"))">
                <MudText Typo="Typo.caption" Class="text-muted">Strategies</MudText>
                <MudText Typo="Typo.h5">@_strategies.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Last Sharpe</MudText>
                <MudText Typo="Typo.h5">@(_latestRun?.SharpeRatio?.ToString("F2") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Active Studies</MudText>
                <MudText Typo="Typo.h5">@_activeStudies</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">⚠ Flags</MudText>
                <MudText Typo="Typo.h5">@_warningRuns.Count</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Zone 3 — Two-column body *@
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.subtitle2" Class="text-muted mb-2">RECENT RUNS</MudText>
            @if (_recentRuns.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No runs yet.</MudAlert>
            }
            else
            {
                @* Fix 3+4: Strategy as hub link + Date column *@
                <MudTable Items="_recentRuns" Dense="true" Hover="true" Class="mb-4">
                    <HeaderContent>
                        <MudTh>Strategy</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Sharpe</MudTh>
                        <MudTh>Max DD</MudTh>
                        <MudTh>Trades</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @if (_strategyIdByType.TryGetValue(context.ScenarioConfig.StrategyType, out var sid))
                            {
                                <MudLink Href="@($"/strategies/{sid}")">@context.ScenarioConfig.StrategyType</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@context.ScenarioConfig.StrategyType</MudText>
                            }
                        </MudTd>
                        <MudTd><MudText Typo="Typo.body2" Class="text-muted">@(TryParseRunDate(context.Id)?.ToString("yyyy-MM-dd") ?? "—")</MudText></MudTd>
                        <MudTd Class="@GetSharpeClass(context.SharpeRatio)">@(context.SharpeRatio?.ToString("F2") ?? "—")</MudTd>
                        <MudTd>@context.MaxDrawdown.ToString("P1")</MudTd>
                        <MudTd>@context.TotalTrades</MudTd>
                        <MudTd><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="MudBlazor.Size.Small" Href="@($"/backtests/{context.Id}")" /></MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudItem>
        <MudItem xs="12" md="4">
            @if (_warningRuns.Count > 0)
            {
                @* Fix 5: Hub link + run icon *@
                <MudText Typo="Typo.subtitle2" Class="text-muted mb-2">⚠ ROBUSTNESS FLAGS</MudText>
                @foreach (var (run, warnings) in _warningRuns)
                {
                    <MudPaper Outlined="true" Class="pa-2 mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                            @if (_strategyIdByType.TryGetValue(run.ScenarioConfig.StrategyType, out var flagSid))
                            {
                                <MudLink Href="@($"/strategies/{flagSid}")" Typo="Typo.body2">@run.ScenarioConfig.StrategyType</MudLink>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@run.ScenarioConfig.StrategyType</MudText>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="MudBlazor.Size.Small" Class="text-muted"
                                           Href="@($"/backtests/{run.Id}")" aria-label="View run result" />
                        </MudStack>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @foreach (var w in warnings)
                            {
                                <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning">@w</MudChip>
                            }
                        </MudStack>
                    </MudPaper>
                }
            }
        </MudItem>
    </MudGrid>

    @* V4: Research Pipeline *@
    @if (_stageGroups.Count > 0)
    {
        <MudPaper Outlined="true" Class="pa-3 mt-4 mb-2">
            <MudText Typo="Typo.subtitle2" Class="text-muted mb-2">RESEARCH PIPELINE</MudText>
            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                @foreach (var g in _stageGroups)
                {
                    <MudText Typo="Typo.body2">@g.Count @g.Stage</MudText>
                }
            </MudStack>
        </MudPaper>
    }

    @* Zone 4 — Nav cards (Fix 6) *@
    <MudGrid Class="mt-4">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-3" Elevation="1" Style="cursor:pointer"
                      @onclick="@(() => Nav.NavigateTo("/research/explorer"))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Science" Class="text-muted" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">Research Explorer</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">Browse all studies</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-3" Elevation="1" Style="cursor:pointer"
                      @onclick="@(() => Nav.NavigateTo("/propfirm/evaluate"))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="text-muted" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">Prop Firm Lab</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">Evaluate against firm rules</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-3" Elevation="1" Style="cursor:pointer"
                      @onclick="@(() => Nav.NavigateTo("/data"))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Class="text-muted" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">Data Files</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">Manage market data</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private readonly CancellationTokenSource _cts = new();

    private List<StrategyIdentity> _strategies = new();
    private List<BacktestResult> _runs = new();
    private List<BacktestResult> _recentRuns = new();
    private BacktestResult? _latestRun;
    private int _activeStudies;
    private Dictionary<string, BacktestResult> _lastRunMap = new();
    private Dictionary<string, string> _strategyIdByType = new(); // Fix 2
    private List<(BacktestResult Run, List<string> Warnings)> _warningRuns = new();
    private List<(int Count, DevelopmentStage Stage)> _stageGroups = new(); // V4
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _strategies = (await StrategyRepo.ListAsync(_cts.Token)).ToList();
            _runs = (await ResultRepo.ListAsync(_cts.Token)).OrderByDescending(r => r.RunId).ToList();
            _recentRuns = _runs.Take(10).ToList();
            _latestRun = _runs.FirstOrDefault();
            var studies = (await StudyRepo.ListAsync(_cts.Token)).ToList();
            _activeStudies = studies.Count(s => s.Status == TradingResearchEngine.Application.Research.StudyStatus.Running);

            _lastRunMap = _runs
                .GroupBy(r => r.ScenarioConfig.StrategyType)
                .ToDictionary(g => g.Key, g => g.First());

            // Fix 2: strategy ID lookup by type
            _strategyIdByType = _strategies
                .GroupBy(s => s.StrategyType)
                .ToDictionary(g => g.Key, g => g.First().StrategyId);

            foreach (var run in _runs.Where(r => r.Status == BacktestStatus.Completed).Take(10))
            {
                var w = RobustnessService.GetWarnings(run);
                if (w.Count > 0) _warningRuns.Add((run, w.ToList()));
            }

            // V4: Research pipeline stage groups
            _stageGroups = _strategies
                .GroupBy(s => s.Stage)
                .OrderBy(g => g.Key)
                .Select(g => (Count: g.Count(), Stage: g.Key))
                .ToList();

            _loading = false;
        }
        catch (OperationCanceledException)
        {
            // Component was disposed during loading — do not update state
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private static string GetSharpeClass(decimal? sharpe) => sharpe switch
    {
        >= 1.5m => "mud-success-text",
        >= 0.8m => "mud-warning-text",
        _ => "mud-error-text"
    };

    // Fix 4: Parse run date from RunId prefix
    private static DateTime? TryParseRunDate(string? runId)
    {
        if (string.IsNullOrWhiteSpace(runId) || runId.Length < 15) return null;
        if (DateTime.TryParseExact(runId[..15], "yyyyMMdd-HHmmss",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            return dt;
        return null;
    }
}
