@page "/data"
@inject TradingResearchEngine.Infrastructure.DataProviders.DataFileService DataService
@inject ISnackbar Snackbar

<PageTitle>Data Files — TradingResearchEngine</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Data Files</MudText>
<MudText Typo="Typo.caption" Class="mb-4" Style="opacity:0.6">
    Directory: @DataService.DataDirectory
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="_files" Dense="true" Hover="true" Striped="true"
              OnRowClick="OnRowClick" T="TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo">
        <HeaderContent>
            <MudTh>File</MudTh>
            <MudTh>Format</MudTh>
            <MudTh>Rows</MudTh>
            <MudTh>Size</MudTh>
            <MudTh>First Date</MudTh>
            <MudTh>Last Date</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FileName</MudTd>
            <MudTd><MudChip T="string" Size="MudBlazor.Size.Small">@context.DetectedFormat</MudChip></MudTd>
            <MudTd>@context.RowCount.ToString("N0")</MudTd>
            <MudTd>@FormatSize(context.FileSizeBytes)</MudTd>
            <MudTd>@(context.FirstTimestamp ?? "—")</MudTd>
            <MudTd>@(context.LastTimestamp ?? "—")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="MudBlazor.Size.Small"
                               OnClick="@(() => Preview(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="MudBlazor.Size.Small"
                               OnClick="@(() => Validate(context))" />
                @if (context.DetectedFormat != "Engine")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Transform" Size="MudBlazor.Size.Small"
                                   Color="MudBlazor.Color.Primary"
                                   OnClick="@(() => Convert(context))" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>

    @if (_files.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            No CSV files found. Place CSV files in the data directory or use Dukascopy to download data.
        </MudAlert>
    }

    @if (_previewData is not null)
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">Preview: @_previewFile</MudText>
            <MudSimpleTable Dense="true" Hover="true" Style="overflow-x: auto;">
                <thead>
                    <tr>
                        @if (_previewData.Count > 0)
                        {
                            @foreach (var col in _previewData[0])
                            {
                                <th>@col</th>
                            }
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _previewData.Skip(1))
                    {
                        <tr>
                            @foreach (var cell in row)
                            {
                                <td>@cell</td>
                            }
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
}

@code {
    private List<TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo> _files = new();
    private List<string[]>? _previewData;
    private string? _previewFile;
    private bool _loading = true;

    protected override void OnInitialized()
    {
        _files = DataService.ListFiles();
        _loading = false;
    }

    private void OnRowClick(TableRowClickEventArgs<TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo> args)
    {
        if (args.Item is not null) Preview(args.Item);
    }

    private void Preview(TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo file)
    {
        _previewData = DataService.PreviewFile(file.FullPath);
        _previewFile = file.FileName;
    }

    private void Validate(TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo file)
    {
        var (valid, msg) = DataService.ValidateSchema(file.FullPath);
        Snackbar.Add(msg, valid ? Severity.Success : Severity.Warning);
    }

    private void Convert(TradingResearchEngine.Infrastructure.DataProviders.DataFileInfo file)
    {
        try
        {
            var outputPath = DataService.ConvertToEngineFormat(file.FullPath);
            Snackbar.Add($"Converted to: {Path.GetFileName(outputPath)}", Severity.Success);
            _files = DataService.ListFiles(); // refresh
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Conversion failed: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
