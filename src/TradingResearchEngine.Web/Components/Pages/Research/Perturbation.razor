@page "/research/perturbation"
@inject TradingResearchEngine.Application.Research.ParameterPerturbationWorkflow PertWorkflow
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject IStrategyRepository StrategyRepo
@inject ISnackbar Snackbar

<PageTitle>Parameter Perturbation — TradingResearchEngine</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Parameter Perturbation</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Jitters each parameter by ±N% to detect curve-fitting. Stable results = robust strategy.
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <StrategyVersionPicker PreselectedStrategyId="@StrategyId" PreselectedVersionId="@VersionId"
                                   OnSelectionChanged="OnVersionSelected" />

            <MudExpansionPanels Class="mt-3 mb-3">
                <MudExpansionPanel Text="Advanced / Manual Config" Expanded="false">
                    <ScenarioConfigEditor @ref="_configEditor" />
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudDivider Class="my-4" />
            <MudNumericField T="int" Label="Run Count" @bind-Value="_runCount"
                             Variant="Variant.Outlined" Class="mb-2" Min="5" Max="500" />
            <MudNumericField T="decimal" Label="Jitter %" @bind-Value="_jitter"
                             Variant="Variant.Outlined" Class="mb-2" Min="0.01M" Max="0.50M" Step="0.05M" />

            <WorkflowRunner TResult="TradingResearchEngine.Application.Research.PerturbationResult"
                            ButtonText="Run Perturbation"
                            OnExecute="Execute">
                <ResultContent Context="result">
                    <MudGrid>
                        <MudItem xs="4"><MetricCard Label="Mean Sharpe" Value="@result.MeanSharpe.ToString("F2")" /></MudItem>
                        <MudItem xs="4"><MetricCard Label="Std Dev" Value="@result.StdDevSharpe.ToString("F3")" /></MudItem>
                        <MudItem xs="4"><MetricCard Label="Mean Expectancy" Value="@($"${result.MeanExpectancy:F2}")" /></MudItem>
                        <MudItem xs="6"><MetricCard Label="Worst Sharpe" Value="@result.WorstSharpe.ToString("F2")" /></MudItem>
                        <MudItem xs="6"><MetricCard Label="Best Sharpe" Value="@result.BestSharpe.ToString("F2")" /></MudItem>
                    </MudGrid>
                </ResultContent>
            </WorkflowRunner>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery] public string? StrategyId { get; set; }
    [SupplyParameterFromQuery] public string? VersionId { get; set; }
    [SupplyParameterFromQuery(Name = "result")] public string? ResultId { get; set; }

    private ScenarioConfigEditor? _configEditor;
    private int _runCount = 50;
    private decimal _jitter = 0.10m;

    private void OnVersionSelected((StrategyIdentity Strategy, StrategyVersion Version, BacktestResult? LatestRun) selection)
    {
        _configEditor?.LoadFromConfig(selection.Version.BaseScenarioConfig);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ResultId is not null && _configEditor is not null)
        {
            var result = await ResultRepo.GetByIdAsync(ResultId);
            if (result is not null)
                _configEditor.LoadFromConfig(result.ScenarioConfig);
            else
                Snackbar.Add("Backtest result not found.", Severity.Warning);
            StateHasChanged();
        }
    }

    private async Task<TradingResearchEngine.Application.Research.PerturbationResult> Execute(CancellationToken ct)
    {
        var config = _configEditor!.BuildConfig();
        var options = new TradingResearchEngine.Application.Research.PerturbationOptions
        {
            RunCount = _runCount,
            JitterPercent = _jitter
        };
        return await PertWorkflow.RunAsync(config, options, ct);
    }
}
