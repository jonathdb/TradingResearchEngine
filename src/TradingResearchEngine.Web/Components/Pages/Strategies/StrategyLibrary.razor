@page "/strategies/library"
@inject IStrategyRepository StrategyRepo
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject NavigationManager Nav

<PageTitle>My Strategies — Research Engine</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
    <MudTextField @bind-Value="_search" Placeholder="Search strategies..."
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined" Immediate="true" Class="flex-grow-1" />
    <MudSelect T="string" @bind-Value="_typeFilter" Label="Type" Variant="Variant.Outlined"
               Style="min-width:160px" Clearable="true">
        @foreach (var t in _allTypes)
        { <MudSelectItem Value="@t">@t</MudSelectItem> }
    </MudSelect>
    <MudSelect T="string" @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined"
               Style="min-width:140px" Clearable="true">
        <MudSelectItem Value="@("Active")">Active</MudSelectItem>
        <MudSelectItem Value="@("Stale")" Disabled="true">Stale (coming soon)</MudSelectItem>
        <MudSelectItem Value="@("Untested")">Untested</MudSelectItem>
        <MudSelectItem Value="@("Retired")">Retired</MudSelectItem>
    </MudSelect>
    <MudSwitch T="bool" @bind-Value="_showRetired" Label="Show Retired" Color="Color.Secondary" />
    @{
        var retiredCount = _strategies.Count(s => s.Stage == DevelopmentStage.Retired);
    }
    @if (!_showRetired && retiredCount > 0)
    {
        <MudText Typo="Typo.caption" Class="text-muted">@retiredCount retired hidden</MudText>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/strategies/builder">New Strategy</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (FilteredStrategies.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-16">
        <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="MudBlazor.Size.Large" Class="text-faint mb-3" />
        <MudText Typo="Typo.h6">No strategies yet</MudText>
        <MudText Typo="Typo.body2" Class="text-muted mb-4">Create your first strategy to start backtesting</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/strategies/builder">Create Strategy</MudButton>
    </MudStack>
}
else
{
    <MudGrid>
        @foreach (var s in FilteredStrategies)
        {
            var lastRun = _lastRunMap.GetValueOrDefault(s.StrategyType);
            var status = GetStatus(s, lastRun);
            var vCount = _versionCounts.GetValueOrDefault(s.StrategyId, 0);
            var isRetired = s.Stage == DevelopmentStage.Retired;

            <MudItem xs="12" sm="6" md="4">
                <MudCard Outlined="true" Style="@(isRetired ? "position:relative;opacity:0.6" : "position:relative")">
                    @* Status badge *@
                    @if (isRetired)
                    {
                        <MudChip T="string" Size="MudBlazor.Size.Small"
                                 Color="Color.Default"
                                 Style="position:absolute;top:12px;right:12px;background:#9e9e9e;color:white">
                            RETIRED
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="MudBlazor.Size.Small"
                                 Color="@GetStatusColor(status)"
                                 Style="position:absolute;top:12px;right:12px">
                            @status
                        </MudChip>
                    }

                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600">@s.StrategyName</MudText>
                        </MudStack>
                        <MudChip T="string" Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Class="mb-2">@s.StrategyType</MudChip>
                        @if (_strategiesWithWarnings.Contains(s.StrategyType))
                        {
                            <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning"
                                     Icon="@Icons.Material.Filled.Warning" Class="mb-2">Robustness flags</MudChip>
                        }

                        @if (isRetired && !string.IsNullOrWhiteSpace(s.RetirementNote))
                        {
                            <MudText Typo="Typo.caption" Class="text-muted mb-1">Note: @s.RetirementNote</MudText>
                        }

                        <MudText Typo="Typo.body2" Class="text-muted mb-1">@vCount version(s)</MudText>

                        @if (lastRun is not null)
                        {
                            <MudStack Row="true" Spacing="4" Class="mt-2">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Class="text-faint">Sharpe</MudText>
                                    <MudText Typo="Typo.body1" Class="@GetSharpeClass(lastRun.SharpeRatio)">
                                        @(lastRun.SharpeRatio?.ToString("F2") ?? "—")
                                    </MudText>
                                </MudStack>
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Class="text-faint">Max DD</MudText>
                                    <MudText Typo="Typo.body1">@lastRun.MaxDrawdown.ToString("P1")</MudText>
                                </MudStack>
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="text-muted mt-2">
                                Last run: @(TryParseRunDate(lastRun.Id)?.ToString("yyyy-MM-dd") ?? lastRun.Id[..Math.Min(8, lastRun.Id.Length)])
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="text-muted mt-2">No runs yet</MudText>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   Href="@($"/strategies/{s.StrategyId}")">Open Hub</MudButton>
                        @if (!isRetired)
                        {
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text"
                                       Href="@($"/strategies/builder?fromStrategyId={s.StrategyId}&asVersion=true")">New Version</MudButton>
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text"
                                       Href="@($"/strategies/builder?fromStrategyId={s.StrategyId}")">Clone</MudButton>
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="@(() => StartRetire(s))">Retire</MudButton>
                        }
                        else
                        {
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Success"
                                       OnClick="@(() => UnRetire(s))">Un-Retire</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@* V6: Retirement note prompt *@
@if (_retireTarget is not null)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="false">
        <MudCard Style="max-width:400px;margin:auto;margin-top:20vh">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Retire "@_retireTarget.StrategyName"?</MudText>
                <MudTextField @bind-Value="_retirementNote" Label="Why are you retiring this strategy? (optional)"
                              Variant="Variant.Outlined" Lines="3" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" OnClick="CancelRetire">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ConfirmRetire">Retire</MudButton>
            </MudCardActions>
        </MudCard>
    </MudOverlay>
}

@code {
    private List<StrategyIdentity> _strategies = new();
    private Dictionary<string, BacktestResult> _lastRunMap = new();
    private Dictionary<string, int> _versionCounts = new();
    private HashSet<string> _strategiesWithWarnings = new();
    private List<string> _allTypes = new();
    private string _search = "";
    private string? _typeFilter;
    private string? _statusFilter;
    private bool _loading = true;
    private bool _showRetired;
    private StrategyIdentity? _retireTarget;
    private string? _retirementNote;

    private List<StrategyIdentity> FilteredStrategies => _strategies
        .Where(s => _showRetired || s.Stage != DevelopmentStage.Retired)
        .Where(s => string.IsNullOrWhiteSpace(_search) || s.StrategyName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(s => _typeFilter is null || s.StrategyType == _typeFilter)
        .Where(s => _statusFilter is null || GetStatus(s, _lastRunMap.GetValueOrDefault(s.StrategyType)) == _statusFilter)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        _strategies = (await StrategyRepo.ListAsync()).ToList();
        var allRuns = (await ResultRepo.ListAsync()).OrderByDescending(r => r.RunId).ToList();

        _lastRunMap = allRuns
            .GroupBy(r => r.ScenarioConfig.StrategyType)
            .ToDictionary(g => g.Key, g => g.First());

        foreach (var s in _strategies)
        {
            var versions = await StrategyRepo.GetVersionsAsync(s.StrategyId);
            _versionCounts[s.StrategyId] = versions.Count;
        }

        foreach (var (type, run) in _lastRunMap)
        {
            bool hasWarning = (run.SharpeRatio > 3.0m) || (run.TotalTrades < 30) ||
                              (run.EquityCurveSmoothness < 0m) || (run.MaxDrawdown > 0.20m);
            if (hasWarning) _strategiesWithWarnings.Add(type);
        }

        _allTypes = _strategies.Select(s => s.StrategyType).Distinct().OrderBy(t => t).ToList();
        _loading = false;
    }

    private static string GetStatus(StrategyIdentity s, BacktestResult? lastRun)
    {
        if (s.Stage == DevelopmentStage.Retired) return "Retired";
        if (lastRun is null) return "Untested";
        return "Active";
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Stale" => Color.Warning,
        "Retired" => Color.Default,
        _ => Color.Default
    };

    private static string GetSharpeClass(decimal? sharpe) => sharpe switch
    {
        >= 1.5m => "mud-success-text",
        >= 0.8m => "mud-warning-text",
        _ => "mud-error-text"
    };

    private static DateTime? TryParseRunDate(string? runId)
    {
        if (string.IsNullOrWhiteSpace(runId) || runId.Length < 15) return null;
        if (DateTime.TryParseExact(runId[..15], "yyyyMMdd-HHmmss",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            return dt;
        return null;
    }

    private void StartRetire(StrategyIdentity strategy)
    {
        _retireTarget = strategy;
        _retirementNote = null;
    }

    private void CancelRetire()
    {
        _retireTarget = null;
        _retirementNote = null;
    }

    private async Task ConfirmRetire()
    {
        if (_retireTarget is null) return;

        var updated = _retireTarget with
        {
            Stage = DevelopmentStage.Retired,
            RetirementNote = string.IsNullOrWhiteSpace(_retirementNote) ? null : _retirementNote.Trim()
        };
        await StrategyRepo.SaveAsync(updated);

        var idx = _strategies.FindIndex(s => s.StrategyId == updated.StrategyId);
        if (idx >= 0) _strategies[idx] = updated;

        _retireTarget = null;
        _retirementNote = null;
    }

    private async Task UnRetire(StrategyIdentity strategy)
    {
        var updated = strategy with { Stage = DevelopmentStage.Hypothesis };
        await StrategyRepo.SaveAsync(updated);

        var idx = _strategies.FindIndex(s => s.StrategyId == updated.StrategyId);
        if (idx >= 0) _strategies[idx] = updated;
    }
}
