@page "/strategies/builder"
@page "/strategies/builder/{DraftId}"
@using TradingResearchEngine.Web.Components.Builder
@using TradingResearchEngine.Application.DataFiles
@using TradingResearchEngine.Application.Engine
@using TradingResearchEngine.Core.Persistence
@inject IReadOnlyList<StrategyTemplate> Templates
@inject IStrategyRepository StrategyRepo
@inject StrategyRegistry Registry
@inject IStrategySchemaProvider SchemaProvider
@inject IRepository<ConfigDraft> DraftRepo
@inject IRepository<ConfigPreset> PresetRepo
@inject IDataFileRepository DataFileRepo
@inject PreflightValidator PreflightValidator
@inject ResolvedConfigService ResolvedConfigService
@inject RunScenarioUseCase RunUseCase
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Strategy Builder — Research Engine</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Strategy Builder</MudText>

<BuilderStepIndicator CurrentStep="@_vm.CurrentStep" OnStepSelected="GoToStep" />

<MudGrid>
    @* Primary content area (~65%) *@
    <MudItem xs="12" md="8">
        @switch (_vm.CurrentStep)
        {
            case 1:
                <Step1ChooseStartingPoint Model="@_vm"
                                          Templates="@Templates"
                                          Strategies="@_strategies"
                                          KnownStrategies="@_knownStrategies"
                                          OnTemplateSelected="OnTemplateSelected"
                                          OnModelChanged="OnModelChanged" />
                break;
            case 2:
                <Step2DataExecutionWindow Model="@_vm"
                                          DataFiles="@_dataFiles"
                                          OnModelChanged="OnModelChanged" />
                break;
            case 3:
                <Step3StrategyParameters Model="@_vm"
                                         Schemas="@_schemas"
                                         PresetParameters="@_presetParameters"
                                         OnModelChanged="OnModelChanged" />
                break;
            case 4:
                <Step4RealismRiskProfile Model="@_vm"
                                         Presets="@_presets"
                                         OnModelChanged="OnModelChanged" />
                break;
            case 5:
                <Step5ReviewLaunch Model="@_vm"
                                   ResolvedConfig="@_resolvedConfig"
                                   PreflightResult="@_preflightResult"
                                   Saving="@_saving"
                                   OnAction="OnLaunchAction" />
                break;
        }

        @* Step navigation *@
        <MudStack Row="true" Class="mt-4" Justify="Justify.SpaceBetween">
            @if (_vm.CurrentStep > 1)
            {
                <MudButton Variant="Variant.Text" OnClick="PreviousStep"
                           aria-label="Go to previous step">
                    ← Back
                </MudButton>
            }
            else
            {
                <div></div>
            }
            @if (_vm.CurrentStep < 5)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(!CanAdvance())"
                           OnClick="NextStep"
                           aria-label="Go to next step">
                    Next →
                </MudButton>
            }
        </MudStack>
    </MudItem>

    @* Research Summary Rail (~35%) *@
    <MudItem xs="12" md="4">
        <ResearchSummaryRail Model="@_vm"
                             Schemas="@_schemas"
                             PreflightResult="@_preflightResult" />
    </MudItem>
</MudGrid>

@code {
    [Parameter] public string? DraftId { get; set; }

    private BuilderViewModel _vm = new();
    private IReadOnlyList<StrategyIdentity> _strategies = Array.Empty<StrategyIdentity>();
    private IReadOnlyList<string> _knownStrategies = Array.Empty<string>();
    private IReadOnlyList<DataFileRecord> _dataFiles = Array.Empty<DataFileRecord>();
    private IReadOnlyList<StrategyParameterSchema> _schemas = Array.Empty<StrategyParameterSchema>();
    private IReadOnlyList<ConfigPreset> _presets = Array.Empty<ConfigPreset>();
    private Dictionary<string, object>? _presetParameters;
    private PreflightResult? _preflightResult;
    private ResolvedConfig? _resolvedConfig;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        // Load reference data
        _strategies = await StrategyRepo.ListAsync();
        _knownStrategies = Registry.KnownNames;
        _dataFiles = await DataFileRepo.ListAsync();
        _presets = await PresetRepo.ListAsync();

        // Resume draft if ID provided
        if (!string.IsNullOrWhiteSpace(DraftId))
        {
            var draft = await DraftRepo.GetByIdAsync(DraftId);
            if (draft is not null)
            {
                _vm = BuilderViewModel.FromDraft(draft);
                LoadSchemaForCurrentStrategy();
            }
        }
    }

    private Task OnTemplateSelected(StrategyTemplate tpl)
    {
        _vm.TemplateId = tpl.TemplateId;
        _vm.StrategyType = tpl.StrategyType;
        _vm.Parameters = new Dictionary<string, object>(tpl.DefaultParameters);
        _vm.Timeframe = tpl.RecommendedTimeframe;
        _vm.Hypothesis ??= tpl.Descriptor?.Hypothesis;
        _vm.IsDirty = true;

        _presetParameters = new Dictionary<string, object>(tpl.DefaultParameters);
        LoadSchemaForCurrentStrategy();
        return Task.CompletedTask;
    }

    private void LoadSchemaForCurrentStrategy()
    {
        if (_vm.StrategyType is not null)
        {
            try { _schemas = SchemaProvider.GetSchema(_vm.StrategyType); }
            catch { _schemas = Array.Empty<StrategyParameterSchema>(); }
        }
    }

    private async Task NextStep()
    {
        if (!CanAdvance()) return;
        _vm.CurrentStep++;
        _vm.IsDirty = true;
        await PersistDraft();

        // Load resolved config and preflight on step 5
        if (_vm.CurrentStep == 5)
            await RunPreflightAndResolve();
    }

    private async Task PreviousStep()
    {
        if (_vm.CurrentStep > 1)
        {
            _vm.CurrentStep--;
            await PersistDraft();
        }
    }

    private async Task GoToStep(int step)
    {
        if (step < _vm.CurrentStep)
        {
            _vm.CurrentStep = step;
            await PersistDraft();
        }
    }

    private async Task PersistDraft()
    {
        try
        {
            var draft = _vm.ToConfigDraft();
            await DraftRepo.SaveAsync(draft);
            _vm.IsDirty = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save draft: {ex.Message}", Severity.Warning);
        }
    }

    private async Task RunPreflightAndResolve()
    {
        try
        {
            var config = _vm.ToScenarioConfig();
            _preflightResult = PreflightValidator.Validate(config);
            _resolvedConfig = await ResolvedConfigService.ResolveAsync(config, _vm.PresetId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Preflight error: {ex.Message}", Severity.Warning);
        }
    }

    private Task OnModelChanged()
    {
        _vm.IsDirty = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool CanAdvance() => _vm.CurrentStep switch
    {
        1 => (_vm.SourceType == SourceType.Template && _vm.TemplateId is not null) ||
             _vm.SourceType == SourceType.Manual ||
             _vm.SourceType == SourceType.Fork ||
             _vm.SourceType == SourceType.Import,
        2 => !string.IsNullOrWhiteSpace(_vm.DataFilePath),
        3 => true,
        4 => true,
        _ => false
    };

    private async Task OnLaunchAction(string action)
    {
        _saving = true;
        StateHasChanged();

        try
        {
            switch (action)
            {
                case "save-draft":
                    await SaveDraftAndVersion();
                    Snackbar.Add("Draft saved.", Severity.Success);
                    Nav.NavigateTo("/strategies/library");
                    break;

                case "quick-sanity":
                    var (_, version) = await SaveDraftAndVersion();
                    var quickConfig = _vm.ToScenarioConfig();
                    // Override to FastResearch for quick sanity
                    var result = await Task.Run(() => RunUseCase.RunAsync(quickConfig));
                    HandleRunResult(result);
                    break;

                case "standard-backtest":
                    var (_, sv) = await SaveDraftAndVersion();
                    var stdConfig = _vm.ToScenarioConfig();
                    var stdResult = await Task.Run(() => RunUseCase.RunAsync(stdConfig));
                    HandleRunResult(stdResult);
                    break;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task<(StrategyIdentity, StrategyVersion)> SaveDraftAndVersion()
    {
        var strategyId = _vm.StrategyName.ToLowerInvariant().Replace(" ", "-");
        if (string.IsNullOrWhiteSpace(strategyId))
            strategyId = $"strategy-{Guid.NewGuid():N}".Substring(0, 20);

        var identity = new StrategyIdentity(strategyId, _vm.StrategyName,
            _vm.StrategyType ?? "", DateTimeOffset.UtcNow, null,
            Hypothesis: _vm.Hypothesis);
        await StrategyRepo.SaveAsync(identity);

        var version = _vm.ToStrategyVersion(strategyId, 1);
        await StrategyRepo.SaveVersionAsync(version);

        // Persist final draft
        await PersistDraft();

        return (identity, version);
    }

    private void HandleRunResult(dynamic result)
    {
        if (result.IsSuccess && result.Result is not null)
        {
            Snackbar.Add($"Backtest completed: {result.Result.TotalTrades} trades", Severity.Success);
            Nav.NavigateTo($"/backtests/{result.Result.RunId}");
        }
        else
        {
            Snackbar.Add($"Run failed: {string.Join("; ", result.Errors ?? Array.Empty<string>())}", Severity.Error);
        }
    }
}
