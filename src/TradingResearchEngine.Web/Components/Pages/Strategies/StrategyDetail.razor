    // V4: Stage color
    private Color StageColor => _strategy?.Stage switch
    {
        DevelopmentStage.Hypothesis => Color.Default,
        DevelopmentStage.Exploring => Color.Info,
        DevelopmentStage.Optimizing => Color.Warning,
        DevelopmentStage.Validating => Color.Primary,
        DevelopmentStage.FinalTest => Color.Success,
        DevelopmentStage.Retired => Color.Dark,
        _ => Color.Default
    };

    // Strategy library curation: family color
    private Color FamilyColor => _descriptor?.Family switch
    {
        StrategyFamily.Trend => Color.Info,
        StrategyFamily.MeanReversion => Color.Secondary,
        StrategyFamily.Breakout => Color.Warning,
        StrategyFamily.RegimeAware => Color.Tertiary,
        StrategyFamily.Benchmark => Color.Default,
        _ => Color.Default
    };

    // V4: Execution Window
    private void OpenEditWindowDialog()
    {
        _editTimeframe = _execWindow.Timeframe;
        _editStartDate = _execWindow.Start?.DateTime;
        _editEndDate = _execWindow.End?.DateTime;
        _editWindowErrors.Clear();
        _editWindowOpen = true;
    }

    private async Task SaveExecutionWindow()
    {
        if (_selectedVersion is null) return;

        var start = _editStartDate.HasValue ? new DateTimeOffset(_editStartDate.Value, TimeSpan.Zero) : (DateTimeOffset?)null;
        var end = _editEndDate.HasValue ? new DateTimeOffset(_editEndDate.Value, TimeSpan.Zero) : (DateTimeOffset?)null;

        var result = TradingResearchEngine.Application.Engine.ExecutionWindowEditor.Validate(
            _selectedVersion, _editTimeframe, start, end);

        if (!result.Success)
        {
            _editWindowErrors = result.Errors.ToList();
            return;
        }

        _selectedVersion = result.UpdatedVersion!;
        await StrategyRepo.SaveVersionAsync(_selectedVersion);
        await LoadVersionData();
        _editWindowOpen = false;
        Snackbar.Add("Execution window updated.", Severity.Success);
        StateHasChanged();
    }

    // Fix 16: Parse run date from RunId
    private static DateTime? TryParseRunDate(string? runId)
    {
        if (string.IsNullOrWhiteSpace(runId) || runId.Length < 15) return null;
        if (DateTime.TryParseExact(runId[..15], "yyyyMMdd-HHmmss",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            return dt;
        return null;
    }
