@page "/strategies/{StrategyId}"
@inject IStrategyRepository StrategyRepo
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject TradingResearchEngine.Application.Research.IStudyRepository StudyRepo
@inject NavigationManager Nav

<PageTitle>@(_strategy?.StrategyName ?? "Strategy") — Research Engine</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_strategy is null)
{
    <MudAlert Severity="Severity.Warning">Strategy not found.</MudAlert>
}
else
{
    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">@_strategy.StrategyName</MudText>
            <MudText Typo="Typo.caption" Class="text-muted">
                @_strategy.StrategyType · Created @_strategy.CreatedAt.ToString("yyyy-MM-dd")
            </MudText>
        </MudStack>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   Href="@($"/backtests/new?strategy={_strategy.StrategyType}&strategyId={_strategy.StrategyId}&versionId={_selectedVersion?.StrategyVersionId}")">Run</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_strategy.Description))
    {
        <MudText Typo="Typo.body2" Class="text-muted mb-4">@_strategy.Description</MudText>
    }

    @* Version bar with tooltips *@
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-4">
        @foreach (var v in _versions)
        {
            <MudTooltip Text="@($"v{v.VersionNumber} · {v.CreatedAt:yyyy-MM-dd} · {v.ChangeNote ?? "no notes"}")">
                <MudChip T="string" Size="MudBlazor.Size.Small"
                         Color="@(v.StrategyVersionId == _selectedVersion?.StrategyVersionId ? Color.Primary : Color.Default)"
                         Variant="@(v.StrategyVersionId == _selectedVersion?.StrategyVersionId ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => SelectVersion(v))">
                    v@(v.VersionNumber)
                </MudChip>
            </MudTooltip>
        }
    </MudStack>

    @* KPI row — always visible *@
    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Sharpe</MudText>
                <MudText Typo="Typo.h5">@(_latestRun?.SharpeRatio?.ToString("F2") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Max DD</MudText>
                <MudText Typo="Typo.h5">@(_latestRun?.MaxDrawdown.ToString("P1") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Studies</MudText>
                <MudText Typo="Typo.h5">@_versionStudies.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.caption" Class="text-muted">Runs</MudText>
                <MudText Typo="Typo.h5">@_versionRuns.Count</MudText>
                @if (_versionRuns.Count == 0)
                {
                    <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="mt-1"
                               Href="@($"/backtests/new?strategy={_strategy.StrategyType}")">Run Now</MudButton>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Tabs *@
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="Runs">
            @if (_versionRuns.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="MudBlazor.Size.Large" Class="text-faint mb-2" />
                    <MudText Typo="Typo.body1">No runs yet</MudText>
                    <MudText Typo="Typo.body2" Class="text-muted mb-4">Run a backtest to see results here</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               Href="@($"/backtests/new?strategy={_strategy.StrategyType}")">Run Backtest →</MudButton>
                </MudStack>
            }
            else
            {
                <MudTable Items="_versionRuns" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Scenario</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Sharpe</MudTh>
                        <MudTh>Max DD</MudTh>
                        <MudTh>Trades</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudLink Href="@($"/backtests/{context.Id}")">@context.ScenarioConfig.ScenarioId</MudLink></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="MudBlazor.Size.Small"
                                     Color="@(context.Status == BacktestStatus.Completed ? Color.Success : Color.Error)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd>@(context.SharpeRatio?.ToString("F2") ?? "—")</MudTd>
                        <MudTd>@context.MaxDrawdown.ToString("P1")</MudTd>
                        <MudTd>@context.TotalTrades</MudTd>
                        <MudTd>
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                       Href="@($"/backtests/{context.Id}")">Open</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Studies">
            @if (_versionStudies.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Science" Size="MudBlazor.Size.Large" Class="text-faint mb-2" />
                    <MudText Typo="Typo.body1">No studies yet</MudText>
                    <MudText Typo="Typo.body2" Class="text-muted mb-4">Run a backtest, then launch a study from the result page</MudText>
                    @if (_latestRun is not null)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   Href="@($"/backtests/{_latestRun.Id}")">Go to Latest Run →</MudButton>
                    }
                </MudStack>
            }
            else
            {
                <MudTable Items="_versionStudies" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Type</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="MudBlazor.Size.Small"
                                     Color="@(context.Status == TradingResearchEngine.Application.Research.StudyStatus.Completed ? Color.Success : Color.Warning)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd>
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                       Href="@($"/research/study/{context.StudyId}")">Open</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Evaluations">
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="MudBlazor.Size.Large" Class="text-faint mb-2" />
                <MudText Typo="Typo.body1">Prop firm evaluations</MudText>
                <MudText Typo="Typo.body2" Class="text-muted mb-4">Evaluations for this strategy will appear here</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Href="/propfirm/evaluate">Run an evaluation →</MudButton>
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Parameters">
            @if (_selectedVersion is not null)
            {
                <MudSimpleTable Dense="true" Striped="true">
                    <tbody>
                        @foreach (var p in _selectedVersion.Parameters)
                        {
                            <tr><td>@p.Key</td><td>@p.Value</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public string StrategyId { get; set; } = "";

    private StrategyIdentity? _strategy;
    private List<StrategyVersion> _versions = new();
    private StrategyVersion? _selectedVersion;
    private List<BacktestResult> _versionRuns = new();
    private List<TradingResearchEngine.Application.Research.StudyRecord> _versionStudies = new();
    private BacktestResult? _latestRun;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _strategy = await StrategyRepo.GetAsync(StrategyId);
        if (_strategy is not null)
        {
            _versions = (await StrategyRepo.GetVersionsAsync(StrategyId)).ToList();
            _selectedVersion = _versions.LastOrDefault();
            await LoadVersionData();
        }
        _loading = false;
    }

    private async void SelectVersion(StrategyVersion v)
    {
        _selectedVersion = v;
        await LoadVersionData();
        StateHasChanged();
    }

    private async Task LoadVersionData()
    {
        if (_selectedVersion is null) return;

        var allResults = await ResultRepo.ListAsync();
        _versionRuns = allResults
            .Where(r => r.StrategyVersionId == _selectedVersion.StrategyVersionId)
            .OrderByDescending(r => r.RunId)
            .ToList();
        _latestRun = _versionRuns.FirstOrDefault();

        _versionStudies = (await StudyRepo.ListByVersionAsync(_selectedVersion.StrategyVersionId)).ToList();
    }
}
