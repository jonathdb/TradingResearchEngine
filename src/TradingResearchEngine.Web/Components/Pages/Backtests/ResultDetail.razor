@page "/backtests/{Id}"
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject ISnackbar Snackbar

<PageTitle>Run Detail — Research Engine</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_result is null)
{
    <MudAlert Severity="Severity.Error">Result not found: @Id</MudAlert>
}
else
{
    @* Header *@
    <MudText Typo="Typo.h4" Class="mb-1">@_result.ScenarioConfig.ScenarioId</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-2 text-muted">
        @_result.ScenarioConfig.StrategyType · @_result.TotalTrades trades · @(_result.RunDurationMs)ms
    </MudText>

    @* Breadcrumbs *@
    <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-3" />

    @* Status *@
    <MudChip T="string" Color="@StatusColor" Class="mb-3"
             aria-label="@($"Run status: {_result.Status}")">
        @StatusIcon @_result.Status
    </MudChip>

    @if (_result.Status == BacktestStatus.Failed)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body2">
                    ❌ Run failed · @_result.EquityCurve.Count bars · @_result.TotalTrades trades · @(_result.RunDurationMs)ms
                </MudText>
                @if (_result.FailureDetail is not null)
                {
                    <MudExpansionPanels Dense="true" Class="mt-1">
                        <MudExpansionPanel Text="View Full Error" @bind-Expanded="_errorExpanded">
                            <pre style="white-space:pre-wrap; font-size:0.8rem; max-height:200px; overflow-y:auto;">@_result.FailureDetail</pre>
                            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="CopyErrorToClipboard">Copy to Clipboard</MudButton>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Replay"
                               OnClick="RerunSameConfig">Re-run with same config</MudButton>
                    <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href="@($"/backtests/new?strategy={_result.ScenarioConfig.StrategyType}")">Edit Config &amp; Re-run</MudButton>
                </MudStack>
            </MudStack>
        </MudAlert>
    }
    else if (_result.Status == BacktestStatus.Cancelled)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            ⚠️ Run was cancelled.
            <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Replay"
                       OnClick="RerunSameConfig">Re-run</MudButton>
        </MudAlert>
    }

    @* Tier 1 — Decision metrics (above fold): Sharpe, Max Drawdown, Win Rate, K-Ratio, DSR *@
    <MudGrid Class="mb-3">
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2"
                      Style="@($"border-left: 3px solid {SharpeColor}")">
                <MudText Typo="Typo.caption" Class="text-muted">Sharpe Ratio</MudText>
                <MudText Typo="Typo.h4">@(_result.SharpeRatio?.ToString("F2") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="text-muted">Max Drawdown</MudText>
                <MudText Typo="Typo.h4">@_result.MaxDrawdown.ToString("P1")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="text-muted">Win Rate</MudText>
                <MudText Typo="Typo.h4">@(_result.WinRate?.ToString("P0") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="text-muted">K-Ratio</MudText>
                <MudText Typo="Typo.h4">@(_result.EquityCurveSmoothness?.ToString("F3") ?? "—")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2"
                      Style="@($"border-left: 3px solid {DsrColor}")"
                      title="Deflated Sharpe Ratio — adjusts for multiple testing bias. Below 0.95 suggests possible overfitting.">
                <MudText Typo="Typo.caption" Class="text-muted">DSR</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h4">@(_result.DeflatedSharpeRatio?.ToString("F2") ?? "—")</MudText>
                    @if (_result.DeflatedSharpeRatio < 0.95m)
                    {
                        <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning"
                                 aria-label="Possible overfitting: DSR below 0.95 — after adjusting for multiple trials, the observed Sharpe may not be statistically significant">⚠️</MudChip>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.caption" Class="text-muted">Trial #</MudText>
                <MudText Typo="Typo.h4">@(_result.TrialCount?.ToString() ?? "—")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* V5: Research Readiness badge *@
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
        <MudChip T="string" Size="MudBlazor.Size.Small"
                 Color="@(_researchReadiness ? Color.Success : Color.Warning)"
                 aria-label="@(_researchReadiness ? "Minimum research checklist passed" : "Research checklist incomplete")">
            @(_researchReadiness ? "✅ Minimum Checklist Passed" : "⚠️ Research Incomplete")
        </MudChip>
        @if (_result.DeflatedSharpeRatio < 0.95m)
        {
            <MudChip T="string" Size="MudBlazor.Size.Small" Color="Color.Warning"
                     aria-label="Possible overfitting warning: DSR below 0.95">
                ⚠️ Possible Overfitting
            </MudChip>
        }
    </MudStack>

    @* V5: Realism Assumptions card — always visible *@
    <MudPaper Outlined="true" Class="pa-3 mb-3">
        <MudText Typo="Typo.caption" Class="text-muted mb-2">REALISM ASSUMPTIONS</MudText>
        <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="text-muted">Profile</MudText>
                <MudText Typo="Typo.body2">@_result.ScenarioConfig.EffectiveExecutionConfig.RealismProfile</MudText>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="text-muted">Fill Mode</MudText>
                <MudText Typo="Typo.body2">@_result.ScenarioConfig.EffectiveFillMode</MudText>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="text-muted">Slippage</MudText>
                <MudText Typo="Typo.body2">@_result.ScenarioConfig.SlippageModelType</MudText>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="text-muted">Commission</MudText>
                <MudText Typo="Typo.body2">@_result.ScenarioConfig.CommissionModelType</MudText>
            </MudStack>
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="text-muted">Session</MudText>
                <MudText Typo="Typo.body2">@(_result.ScenarioConfig.EffectiveExecutionConfig.SessionOptions?.SessionCalendarType ?? "None")</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    @* V5: IS vs OOS comparison panel (when available) *@
    @if (_isOosAvailable)
    {
        <MudPaper Outlined="true" Class="pa-3 mb-3">
            <MudText Typo="Typo.caption" Class="text-muted mb-2">IN-SAMPLE vs OUT-OF-SAMPLE</MudText>
            <MudText Typo="Typo.body2" Class="text-muted">IS vs OOS comparison data available from walk-forward studies. View the study for detailed breakdown.</MudText>
        </MudPaper>
    }

    @* Robustness warnings — V5: enhanced with explanations *@
    <RobustnessWarnings Result="_result" />

    @* Tier 2 — Supporting metrics (tabs): Sortino, Calmar, Profit Factor, Expectancy, Recovery Factor, Avg Holding Period *@
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3" Class="mb-3">
        <MudTabPanel Text="Extended Metrics">
            <MudGrid>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Sortino</MudText>
                        <MudText Typo="Typo.h6">@(_result.SortinoRatio?.ToString("F2") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Calmar</MudText>
                        <MudText Typo="Typo.h6">@(_result.CalmarRatio?.ToString("F2") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Profit Factor</MudText>
                        <MudText Typo="Typo.h6">@(_result.ProfitFactor?.ToString("F2") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Expectancy</MudText>
                        <MudText Typo="Typo.h6">@(_result.Expectancy?.ToString("F2") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Recovery</MudText>
                        <MudText Typo="Typo.h6">@(_result.RecoveryFactor?.ToString("F2") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudPaper Class="pa-3" Elevation="1">
                        <MudText Typo="Typo.caption" Class="text-muted">Avg Hold</MudText>
                        <MudText Typo="Typo.h6">@(_result.AverageHoldingPeriod?.ToString(@"d\.hh\:mm") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Trade Stats">
            <MudGrid>
                <MudItem xs="4" sm="2"><MetricCard Label="RoMaD" Value="@($"{_result.ReturnOnMaxDrawdown?.ToString("F2") ?? "—"}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Avg Win" Value="@($"${_result.AverageWin?.ToString("F2") ?? "—"}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Avg Loss" Value="@($"${_result.AverageLoss?.ToString("F2") ?? "—"}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Consec Wins" Value="@_result.MaxConsecutiveWins.ToString()" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Consec Losses" Value="@_result.MaxConsecutiveLosses.ToString()" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Trades" Value="@_result.TotalTrades.ToString()" /></MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>

    @* Tier 3 — Expanders: regime breakdown, MAE/MFE, event trace *@
    <MudExpansionPanels Class="mb-4">
        <MudExpansionPanel Text="Trade Statistics" aria-label="Expand trade statistics">
            <MudGrid>
                <MudItem xs="4" sm="2"><MetricCard Label="Start Equity" Value="@($"${_result.StartEquity:F0}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="End Equity" Value="@($"${_result.EndEquity:F0}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Consec Wins" Value="@_result.MaxConsecutiveWins.ToString()" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Consec Losses" Value="@_result.MaxConsecutiveLosses.ToString()" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Avg Win" Value="@($"${_result.AverageWin?.ToString("F2") ?? "—"}")" /></MudItem>
                <MudItem xs="4" sm="2"><MetricCard Label="Avg Loss" Value="@($"${_result.AverageLoss?.ToString("F2") ?? "—"}")" /></MudItem>
            </MudGrid>
        </MudExpansionPanel>
        <MudExpansionPanel Text="Performance by Regime" aria-label="Expand regime breakdown">
            <MudText Typo="Typo.body2" Class="text-muted">
                Regime segmentation data is available after running a Regime Segmentation study.
                Launch one from the Study actions above.
            </MudText>
        </MudExpansionPanel>
        @if (_result.ScenarioConfig.EnableEventTrace)
        {
            <MudExpansionPanel Text="Event Trace" aria-label="Expand event trace">
                <MudText Typo="Typo.body2" Class="text-muted">
                    Event trace was enabled for this run. Trace data is available in the exported JSON result.
                </MudText>
            </MudExpansionPanel>
        }
    </MudExpansionPanels>

    @* Action band — Study + Prop Firm *@
    @if (_result.Status == BacktestStatus.Completed)
    {
        <MudPaper Outlined="true" Class="pa-3 mb-4">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Class="text-muted mr-2">STUDY</MudText>
                <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           Href="@($"/research/montecarlo?result={_result.Id}")">Monte Carlo</MudButton>
                <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           Href="@($"/research/walkforward?strategy={_result.ScenarioConfig.StrategyType}")">Walk-Forward</MudButton>
                <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           Href="@($"/research/sweep?strategy={_result.ScenarioConfig.StrategyType}")">Sweep</MudButton>
                <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           Href="@($"/research/perturbation?result={_result.Id}")">Perturbation</MudButton>
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                <MudText Typo="Typo.caption" Class="text-muted mr-2">PROP FIRM</MudText>
                <MudButton Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           Href="@($"/propfirm/evaluate?resultId={_result.Id}")">Evaluate</MudButton>
            </MudStack>
        </MudPaper>
    }

    @* Chart tabs *@
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="Equity">
            <EquityCurveChart Data="_result.EquityCurve" />
        </MudTabPanel>
        <MudTabPanel Text="Drawdown">
            <DrawdownChart Data="_result.EquityCurve" />
        </MudTabPanel>
        <MudTabPanel Text="Trades">
            <MudTable Items="_result.Trades" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Symbol</MudTh>
                    <MudTh>Entry</MudTh>
                    <MudTh>Exit</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh>Entry $</MudTh>
                    <MudTh>Exit $</MudTh>
                    <MudTh>Net P&amp;L</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Symbol</MudTd>
                    <MudTd>@context.EntryTime.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@context.ExitTime.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@context.Quantity</MudTd>
                    <MudTd>$@context.EntryPrice.ToString("F2")</MudTd>
                    <MudTd>$@context.ExitPrice.ToString("F2")</MudTd>
                    <MudTd Class="@(context.NetPnl >= 0 ? "mud-success-text" : "mud-error-text")">
                        $@context.NetPnl.ToString("F2")
                    </MudTd>
                </RowTemplate>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        </MudTabPanel>
        <MudTabPanel Text="P&amp;L">
            <MudGrid>
                <MudItem xs="12" md="8"><TradePnlHistogram Trades="_result.Trades" /></MudItem>
                <MudItem xs="12" md="4"><WinLossDonut TotalTrades="_result.TotalTrades" WinRate="_result.WinRate" /></MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Config">
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <tbody>
                    <tr><td>Strategy</td><td>@_result.ScenarioConfig.StrategyType</td></tr>
                    <tr><td>Data Provider</td><td>@_result.ScenarioConfig.DataProviderType</td></tr>
                    <tr><td>Initial Cash</td><td>$@_result.ScenarioConfig.InitialCash.ToString("F0")</td></tr>
                    <tr><td>Fill Mode</td><td>@_result.ScenarioConfig.FillMode</td></tr>
                    <tr><td>Bars/Year</td><td>@_result.ScenarioConfig.BarsPerYear</td></tr>
                    <tr><td>Slippage</td><td>@_result.ScenarioConfig.SlippageModelType</td></tr>
                    <tr><td>Commission</td><td>@_result.ScenarioConfig.CommissionModelType</td></tr>
                    <tr><td>Equity Points</td><td>@_result.EquityCurve.Count</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>
    </MudTabs>

    @* Export — V4: unified export menu *@
    <MudStack Row="true" Spacing="2" Class="mt-4 mb-4">
        <ExportMenu Result="_result" />
    </MudStack>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private BacktestResult? _result;
    private bool _loading = true;
    private bool _errorExpanded = false;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _researchReadiness; // V5: research readiness badge
    private bool _isOosAvailable; // V5: IS vs OOS comparison available

    private string SharpeColor => _result?.SharpeRatio switch
    {
        > 1.5m => "#4CAF50",
        > 0.5m => "#FF9800",
        _ => "#F44336"
    };

    private string DsrColor => _result?.DeflatedSharpeRatio switch
    {
        >= 0.95m => "#4CAF50",
        >= 0.5m => "#FF9800",
        _ => "#F44336"
    };

    private Color StatusColor => _result?.Status switch
    {
        BacktestStatus.Completed => Color.Success,
        BacktestStatus.Failed => Color.Error,
        BacktestStatus.Cancelled => Color.Warning,
        _ => Color.Default
    };

    private string StatusIcon => _result?.Status switch
    {
        BacktestStatus.Completed => "✅",
        BacktestStatus.Failed => "❌",
        BacktestStatus.Cancelled => "⚠️",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        _result = await ResultRepo.GetByIdAsync(Id);
        if (_result is not null)
        {
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Dashboard", href: "/"),
                new(_result.ScenarioConfig.StrategyType, href: $"/strategies/{_result.StrategyVersionId ?? _result.ScenarioConfig.StrategyType}"),
                new(_result.ScenarioConfig.ScenarioId, href: null, disabled: true)
            };

            // V5: Compute research readiness (minimum: initial backtest + MC + WF)
            // This is a simplified check — full check would use ResearchChecklistService
            _researchReadiness = false;

            // V5: Check if IS vs OOS data is available (walk-forward results)
            _isOosAvailable = false;
        }
        _loading = false;
    }

    private Task CopyErrorToClipboard()
    {
        if (_result?.FailureDetail is null) return Task.CompletedTask;
        // JS interop for clipboard would be ideal; for now use snackbar feedback
        Snackbar.Add("Error copied (use browser dev tools to access clipboard API)", Severity.Info);
        return Task.CompletedTask;
    }

    private void RerunSameConfig()
    {
        if (_result is null) return;
        // Navigate to a new run with the same config pre-filled
        Snackbar.Add("Re-run triggered with same configuration", Severity.Info);
    }

    private async Task ExportMarkdown()
    {
        if (_result is null) return;
        var reporter = new TradingResearchEngine.Infrastructure.Reporting.MarkdownReporter(
            Microsoft.Extensions.Options.Options.Create(
                new TradingResearchEngine.Application.Configuration.ReportingOptions()));
        var md = reporter.RenderToMarkdown(_result);
        var path = GetExportPath($"{_result.ScenarioConfig.ScenarioId}-report.md");
        await File.WriteAllTextAsync(path, md);
        Snackbar.Add($"Saved to {path}", Severity.Success);
    }

    private async Task ExportCsvTradeLog()
    {
        if (_result is null) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Symbol,EntryTime,ExitTime,EntryPrice,ExitPrice,Quantity,Direction,GrossPnl,Commission,NetPnl,ReturnOnRisk");
        foreach (var t in _result.Trades)
            sb.AppendLine($"{t.Symbol},{t.EntryTime:O},{t.ExitTime:O},{t.EntryPrice},{t.ExitPrice},{t.Quantity},{t.Direction},{t.GrossPnl},{t.Commission},{t.NetPnl},{t.ReturnOnRisk:F6}");
        var path = GetExportPath($"{_result.ScenarioConfig.ScenarioId}-trades.csv");
        await File.WriteAllTextAsync(path, sb.ToString());
        Snackbar.Add($"Saved to {path}", Severity.Success);
    }

    private async Task ExportJson()
    {
        if (_result is null) return;
        var json = System.Text.Json.JsonSerializer.Serialize(_result, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var path = GetExportPath($"{_result.ScenarioConfig.ScenarioId}-result.json");
        await File.WriteAllTextAsync(path, json);
        Snackbar.Add($"Saved to {path}", Severity.Success);
    }

    private static string GetExportPath(string fileName)
    {
        var dir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "TradingResearchEngine", "Exports");
        if (!Directory.Exists(dir)) Directory.CreateDirectory(dir);
        return Path.Combine(dir, fileName);
    }
}
