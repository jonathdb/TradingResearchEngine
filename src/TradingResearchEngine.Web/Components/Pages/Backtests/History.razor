@page "/backtests/history"
@inject TradingResearchEngine.Core.Persistence.IRepository<BacktestResult> ResultRepo
@inject ISnackbar Snackbar

<PageTitle>Run History — TradingResearchEngine</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Run History</MudText>
    <MudSpacer />
    @if (_results.Count > 0)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="MudBlazor.Size.Small"
                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="DeleteAllRuns">
            Delete All (@_results.Count)
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_results.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No saved results. <MudLink Href="/strategies/builder">Create a strategy</MudLink> and run a backtest to see results here.
    </MudAlert>
}
else
{
    <MudTable Items="_results" Dense="true" Hover="true" Striped="true"
              Filter="new Func<BacktestResult, bool>(FilterFunc)"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="Search..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="MudBlazor.Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<BacktestResult, object>(x => x.ScenarioConfig.ScenarioId)">Scenario</MudTableSortLabel></MudTh>
            <MudTh>Strategy</MudTh>
            <MudTh>Status</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<BacktestResult, object>(x => x.SharpeRatio ?? 0m)">Sharpe</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<BacktestResult, object>(x => x.MaxDrawdown)">Max DD</MudTableSortLabel></MudTh>
            <MudTh>Trades</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudLink Href="@($"/backtests/{context.Id}")">@context.ScenarioConfig.ScenarioId</MudLink></MudTd>
            <MudTd>@context.ScenarioConfig.StrategyType</MudTd>
            <MudTd>
                <MudChip T="string" Size="MudBlazor.Size.Small"
                         Color="@(context.Status == BacktestStatus.Completed ? Color.Success : Color.Error)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>@(context.SharpeRatio?.ToString("F2") ?? "—")</MudTd>
            <MudTd>@context.MaxDrawdown.ToString("P1")</MudTd>
            <MudTd>@context.TotalTrades</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               Size="MudBlazor.Size.Small"
                               OnClick="@(() => DeleteRun(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private List<BacktestResult> _results = new();
    private string _searchString = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var all = await ResultRepo.ListAsync();
        _results = all.OrderByDescending(r => r.RunId).ToList();
        _loading = false;
    }

    private bool FilterFunc(BacktestResult result)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return result.ScenarioConfig.ScenarioId.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || result.ScenarioConfig.StrategyType.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task DeleteRun(string id)
    {
        await ResultRepo.DeleteAsync(id);
        _results.RemoveAll(r => r.Id == id);
        Snackbar.Add("Run deleted.", Severity.Info);
    }

    private async Task DeleteAllRuns()
    {
        foreach (var r in _results.ToList())
            await ResultRepo.DeleteAsync(r.Id);
        _results.Clear();
        Snackbar.Add("All runs deleted.", Severity.Info);
    }
}
