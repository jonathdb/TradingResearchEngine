@rendermode InteractiveServer
@using Plotly.Blazor
@using Plotly.Blazor.Traces
@using Plotly.Blazor.Traces.ScatterLib
@using TradingResearchEngine.Application.Research.Results

@if (Summary is not null && Summary.CompositeEquityCurve.Count > 0)
{
    <PlotlyChart @ref="_chart" Config="_config" Layout="_layout" Data="_data"
                 style="width:100%; height:400px;" />
}

@code {
    /// <summary>The walk-forward summary containing composite OOS equity curve and windows.</summary>
    [Parameter] public WalkForwardSummary? Summary { get; set; }

    private PlotlyChart? _chart;
    private Config _config = new() { Responsive = true, DisplayModeBar = Plotly.Blazor.ConfigLib.DisplayModeBarEnum.Hover };
    private Layout _layout = new();
    private IList<ITrace> _data = new List<ITrace>();

    protected override void OnParametersSet()
    {
        if (Summary is null || Summary.CompositeEquityCurve.Count == 0) return;

        var curve = Summary.CompositeEquityCurve;
        var timestamps = curve.Select(p => (object)p.Timestamp.DateTime).ToList();
        var equities = curve.Select(p => (object)p.TotalEquity).ToList();

        _data = new List<ITrace>
        {
            // Composite OOS equity curve
            new Scatter
            {
                X = timestamps,
                Y = equities,
                Name = "Composite OOS Equity",
                Mode = ModeFlag.Lines,
                Line = new Line { Color = "#42A5F5", Width = 2m },
                HoverTemplate = "Date: %{x}<br>Equity: $%{y:,.0f}<extra></extra>"
            }
        };

        // Per-window OOS Sharpe as bar chart on secondary Y-axis
        if (Summary.Windows.Count > 0)
        {
            var windowLabels = Summary.Windows.Select(w => (object)$"W{w.WindowIndex}").ToList();
            var sharpes = Summary.Windows.Select(w => (object)(w.OutOfSampleResult.SharpeRatio ?? 0m)).ToList();
            var barColors = Summary.Windows.Select(w =>
                (w.OutOfSampleResult.SharpeRatio ?? 0m) >= 0 ? "rgba(102,187,106,0.7)" : "rgba(239,83,80,0.7)")
                .Cast<object>().ToList();

            _data.Add(new Bar
            {
                X = windowLabels,
                Y = sharpes,
                Name = "OOS Sharpe",
                YAxis = "y2",
                Marker = new Plotly.Blazor.Traces.BarLib.Marker { Color = barColors as IList<object> },
                HoverTemplate = "%{x}<br>OOS Sharpe: %{y:.2f}<extra></extra>"
            });
        }

        // Build window boundary shapes for alternating shading
        var shapes = new List<Plotly.Blazor.LayoutLib.Shape>();
        var colors = new[] { "rgba(66,165,245,0.06)", "rgba(255,167,38,0.06)" };
        for (int i = 0; i < Summary.Windows.Count; i++)
        {
            var w = Summary.Windows[i];
            var oosResult = w.OutOfSampleResult;
            if (oosResult.EquityCurve.Count < 2) continue;

            var x0 = oosResult.EquityCurve[0].Timestamp.DateTime;
            var x1 = oosResult.EquityCurve[^1].Timestamp.DateTime;

            shapes.Add(new Plotly.Blazor.LayoutLib.Shape
            {
                Type = Plotly.Blazor.LayoutLib.ShapeLib.TypeEnum.Rect,
                X0 = (object)x0,
                X1 = (object)x1,
                Y0 = (object)0,
                Y1 = (object)1,
                YRef = "paper",
                FillColor = colors[i % 2],
                Line = new Plotly.Blazor.LayoutLib.ShapeLib.Line { Width = 0m }
            });

            // Vertical dashed line at window boundary
            shapes.Add(new Plotly.Blazor.LayoutLib.Shape
            {
                Type = Plotly.Blazor.LayoutLib.ShapeLib.TypeEnum.Line,
                X0 = (object)x0,
                X1 = (object)x0,
                Y0 = (object)0,
                Y1 = (object)1,
                YRef = "paper",
                Line = new Plotly.Blazor.LayoutLib.ShapeLib.Line { Color = "rgba(255,255,255,0.3)", Dash = "dash", Width = 1m }
            });
        }

        _layout = new Layout
        {
            Title = new Plotly.Blazor.LayoutLib.Title { Text = "Walk-Forward Composite OOS Equity" },
            Margin = new Plotly.Blazor.LayoutLib.Margin { L = 70, R = 70, T = 50, B = 50 },
            HoverMode = Plotly.Blazor.LayoutLib.HoverModeEnum.XUnified,
            ShowLegend = true,
            Legend = new List<Plotly.Blazor.LayoutLib.Legend> { new() { Orientation = Plotly.Blazor.LayoutLib.LegendLib.OrientationEnum.H, Y = -0.15m } },
            XAxis = new[] { new Plotly.Blazor.LayoutLib.XAxis
            {
                Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = "" },
                Type = Plotly.Blazor.LayoutLib.XAxisLib.TypeEnum.Date
            } }.ToList(),
            YAxis = new[]
            {
                new Plotly.Blazor.LayoutLib.YAxis
                {
                    Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = "Equity ($)" }
                }
            }.ToList(),
            Shapes = shapes
        };

        // Add secondary Y-axis for Sharpe bars
        if (Summary.Windows.Count > 0)
        {
            _layout.YAxis.Add(new Plotly.Blazor.LayoutLib.YAxis
            {
                Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = "OOS Sharpe" },
                Overlaying = "y",
                Side = Plotly.Blazor.LayoutLib.YAxisLib.SideEnum.Right,
                ShowGrid = false
            });
        }
    }
}
