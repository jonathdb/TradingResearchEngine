@using ApexCharts
@using TradingResearchEngine.Application.Research.Results

@if (_series is not null && _series.Count > 0)
{
    <ApexChart TItem="McPoint"
               Options="_options"
               Height="450">
        @* Simulated paths — thin, semi-transparent *@
        @foreach (var path in _simPaths)
        {
            <ApexPointSeries TItem="McPoint"
                             Items="path"
                             SeriesType="SeriesType.Line"
                             Name=""
                             XValue="@(p => (decimal)p.Step)"
                             YValue="@(p => p.Equity)"
                             Stroke="@(new SeriesStroke { Width = 1 })" />
        }

        @* P10 band *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p10Band"
                         SeriesType="SeriesType.Line"
                         Name="P10"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 4 })" />

        @* P50 band *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p50Band"
                         SeriesType="SeriesType.Line"
                         Name="P50"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 4 })" />

        @* P90 band *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p90Band"
                         SeriesType="SeriesType.Line"
                         Name="P90"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 4 })" />

        @* Actual result — bold, highlighted *@
        <ApexPointSeries TItem="McPoint"
                         Items="_actualPath"
                         SeriesType="SeriesType.Line"
                         Name="Actual"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 4 })" />
    </ApexChart>
}

@code {
    [Parameter] public MonteCarloResult? McResult { get; set; }
    [Parameter] public IReadOnlyList<TradingResearchEngine.Core.Portfolio.EquityCurvePoint>? ActualEquityCurve { get; set; }
    [Parameter] public decimal StartEquity { get; set; } = 100_000m;

    private List<List<McPoint>>? _simPaths;
    private List<McPoint>? _p10Band;
    private List<McPoint>? _p50Band;
    private List<McPoint>? _p90Band;
    private List<McPoint>? _actualPath;
    private List<object>? _series;

    private ApexChartOptions<McPoint> _options = new()
    {
        Chart = new Chart
        {
            Toolbar = new Toolbar { Show = true },
            Animations = new Animations { Enabled = false }
        },
        Stroke = new Stroke { Curve = Curve.Straight },
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Trade #" } },
        Yaxis = new List<YAxis>
        {
            new() { Labels = new YAxisLabels { Formatter = "function(val) { return '$' + val.toFixed(0); }" },
                    Title = new AxisTitle { Text = "Equity" } }
        },
        Legend = new Legend { Show = true, Position = LegendPosition.Top },
        Tooltip = new Tooltip { Enabled = false }
    };

    protected override void OnParametersSet()
    {
        if (McResult is null) { _series = null; return; }

        // Build simulation paths (limit display to 50 for performance)
        int maxDisplay = Math.Min(50, McResult.SampledPaths.Count);
        _simPaths = new List<List<McPoint>>(maxDisplay);
        for (int i = 0; i < maxDisplay; i++)
        {
            var path = McResult.SampledPaths[i * (McResult.SampledPaths.Count / maxDisplay)];
            _simPaths.Add(path.EquityValues.Select((eq, step) => new McPoint(step, eq)).ToList());
        }

        // Percentile bands
        _p10Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P10)).ToList();
        _p50Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P50)).ToList();
        _p90Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P90)).ToList();

        // Actual equity curve mapped to trade steps
        if (ActualEquityCurve is not null && ActualEquityCurve.Count > 0)
        {
            _actualPath = new List<McPoint> { new(0, StartEquity) };
            for (int i = 0; i < ActualEquityCurve.Count; i++)
                _actualPath.Add(new McPoint(i + 1, ActualEquityCurve[i].TotalEquity));
        }
        else
        {
            _actualPath = new List<McPoint> { new(0, StartEquity) };
        }

        _series = new List<object> { "trigger" }; // non-null to render
    }

    public record McPoint(int Step, decimal Equity);
}
