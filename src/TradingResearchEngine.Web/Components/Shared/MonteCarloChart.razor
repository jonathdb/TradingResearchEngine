@using ApexCharts
@using TradingResearchEngine.Application.Research.Results

@if (_hasData)
{
    <ApexChart TItem="McPoint"
               Options="_options"
               Height="450">

        @* P10 band — dashed, muted *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p10Band"
                         SeriesType="SeriesType.Line"
                         Name="P10"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 6 })" />

        @* P50 band — dashed, slightly brighter *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p50Band"
                         SeriesType="SeriesType.Line"
                         Name="P50 (Median)"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 4 })" />

        @* P90 band — dashed, muted *@
        <ApexPointSeries TItem="McPoint"
                         Items="_p90Band"
                         SeriesType="SeriesType.Line"
                         Name="P90"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 2, DashSpace = 6 })" />

        @* Actual result — bold, highlighted *@
        <ApexPointSeries TItem="McPoint"
                         Items="_actualPath"
                         SeriesType="SeriesType.Line"
                         Name="Actual"
                         XValue="@(p => (decimal)p.Step)"
                         YValue="@(p => p.Equity)"
                         Stroke="@(new SeriesStroke { Width = 4 })" />
    </ApexChart>
}
else
{
    <MudAlert Severity="Severity.Info" Dense="true">No Monte Carlo data to display.</MudAlert>
}

@code {
    [Parameter] public MonteCarloResult? McResult { get; set; }
    [Parameter] public IReadOnlyList<TradingResearchEngine.Core.Portfolio.EquityCurvePoint>? ActualEquityCurve { get; set; }
    [Parameter] public decimal StartEquity { get; set; } = 100_000m;

    private List<McPoint>? _p10Band;
    private List<McPoint>? _p50Band;
    private List<McPoint>? _p90Band;
    private List<McPoint>? _actualPath;
    private bool _hasData;

    private ApexChartOptions<McPoint> _options = new()
    {
        Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Animations = new Animations { Enabled = false },
            Background = "transparent"
        },
        Colors = new List<string> { "#555555", "#888888", "#555555", "#4F98A3" },
        Stroke = new Stroke { Curve = Curve.Straight },
        Xaxis = new XAxis { Title = new AxisTitle { Text = "Trade #" } },
        Yaxis = new List<YAxis>
        {
            new()
            {
                Labels = new YAxisLabels { Formatter = "function(val) { return '$' + val.toFixed(0); }" },
                Title = new AxisTitle { Text = "Equity" }
            }
        },
        Legend = new Legend
        {
            Show = true,
            Position = LegendPosition.Top,
            FontSize = "12px"
        },
        Tooltip = new Tooltip { Enabled = true, Shared = false },
        Grid = new Grid { BorderColor = "#333333" },
        Theme = new Theme { Mode = Mode.Dark }
    };

    protected override void OnParametersSet()
    {
        if (McResult is null || McResult.PercentileBands.Count == 0)
        {
            _hasData = false;
            return;
        }

        // Percentile bands only — no individual sim paths (removes legend clutter)
        _p10Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P10)).ToList();
        _p50Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P50)).ToList();
        _p90Band = McResult.PercentileBands.Select(b => new McPoint(b.Step, b.P90)).ToList();

        // Actual equity curve mapped to trade steps
        if (ActualEquityCurve is not null && ActualEquityCurve.Count > 0)
        {
            _actualPath = new List<McPoint> { new(0, StartEquity) };
            int step = 1;
            // Sample to match percentile band length
            int sampleRate = Math.Max(1, ActualEquityCurve.Count / Math.Max(1, McResult.PercentileBands.Count - 1));
            for (int i = 0; i < ActualEquityCurve.Count && step < McResult.PercentileBands.Count; i += sampleRate)
            {
                _actualPath.Add(new McPoint(step, ActualEquityCurve[i].TotalEquity));
                step++;
            }
        }
        else
        {
            _actualPath = new List<McPoint> { new(0, StartEquity) };
        }

        _hasData = true;
    }

    public record McPoint(int Step, decimal Equity);
}
