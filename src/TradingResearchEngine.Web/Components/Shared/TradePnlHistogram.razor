@using ApexCharts
@if (_buckets is not null && _buckets.Count > 0)
{
    <ApexChart TItem="PnlBucket"
               Title="Trade P&L Distribution"
               Options="_options"
               Height="250">
        <ApexPointSeries TItem="PnlBucket"
                         Items="_buckets"
                         SeriesType="SeriesType.Bar"
                         Name="Trades"
                         XValue="@(b => b.Label)"
                         YValue="@(b => (decimal)b.Count)" />
    </ApexChart>
}

@code {
    [Parameter] public IReadOnlyList<ClosedTrade>? Trades { get; set; }

    private List<PnlBucket>? _buckets;

    protected override void OnParametersSet()
    {
        if (Trades is null || Trades.Count == 0) { _buckets = null; return; }

        var pnls = Trades.Select(t => t.NetPnl).OrderBy(p => p).ToList();
        decimal min = pnls.First();
        decimal max = pnls.Last();
        decimal range = max - min;
        int bucketCount = Math.Min(20, Math.Max(5, Trades.Count / 3));
        if (range == 0) { _buckets = new List<PnlBucket> { new($"${min:F0}", Trades.Count) }; return; }

        decimal bucketSize = range / bucketCount;
        _buckets = new List<PnlBucket>();

        for (int i = 0; i < bucketCount; i++)
        {
            decimal lo = min + i * bucketSize;
            decimal hi = lo + bucketSize;
            int count = pnls.Count(p => p >= lo && (i == bucketCount - 1 ? p <= hi : p < hi));
            _buckets.Add(new PnlBucket($"${lo:F0}", count));
        }
    }

    private ApexChartOptions<PnlBucket> _options = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { ColumnWidth = "90%" }
        },
        Colors = new List<string> { "#66BB6A" }
    };

    public record PnlBucket(string Label, int Count);
}
