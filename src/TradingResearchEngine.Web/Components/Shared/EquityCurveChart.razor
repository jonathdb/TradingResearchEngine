@using ApexCharts
@if (Data is not null && Data.Count > 0)
{
    <ApexChart TItem="EquityCurvePoint"
               Title="Equity Curve"
               Options="_options"
               Height="350">
        <ApexPointSeries TItem="EquityCurvePoint"
                         Items="Data"
                         SeriesType="SeriesType.Line"
                         Name="Equity"
                         XValue="@(p => p.Timestamp.DateTime)"
                         YValue="@(p => p.TotalEquity)" />
    </ApexChart>
}

@code {
    [Parameter] public IReadOnlyList<EquityCurvePoint>? Data { get; set; }

    private ApexChartOptions<EquityCurvePoint> _options = new()
    {
        Chart = new Chart
        {
            Toolbar = new Toolbar { Show = true },
            Zoom = new Zoom { Enabled = true }
        },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
        Xaxis = new XAxis { Type = XAxisType.Datetime },
        Yaxis = new List<YAxis>
        {
            new() { Labels = new YAxisLabels { Formatter = "function(val) { return '$' + val.toFixed(0); }" } }
        },
        Tooltip = new Tooltip { X = new TooltipX { Format = "yyyy-MM-dd" } },
        Colors = new List<string> { "#42A5F5" }
    };
}
